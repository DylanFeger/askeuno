# ===========================================
# Ask Euno - Production Environment Template
# ===========================================
# Copy these values to AWS Amplify Console
# App Settings → Environment Variables
# 
# IMPORTANT: Replace all placeholder values with actual production values!
# See docs/INFRASTRUCTURE_SETUP.md for detailed setup instructions
# ===========================================

# ===========================================
# CORE CONFIGURATION
# ===========================================
# Required: Application environment
NODE_ENV=production

# Optional: Server port (default: 5000)
PORT=5000

# ===========================================
# DATABASE (Production PostgreSQL)
# ===========================================
# Required: PostgreSQL connection string
# Get from: Neon (neon.tech), Supabase, or AWS RDS
# Format: postgresql://user:password@host:port/database?sslmode=require
# 
# Neon.tech: Dashboard → Connection String
# Supabase: Settings → Database → Connection String
# AWS RDS: RDS Console → Endpoint
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ===========================================
# SECURITY (REQUIRED - Generate New Secrets!)
# ===========================================
# Required: Encryption key for sensitive data (AES-256)
# Must be exactly 64 hexadecimal characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 
# ⚠️ DO NOT USE THE DEFAULT VALUE - Generate your own!
ENCRYPTION_KEY=YOUR_64_CHAR_HEX_STRING_HERE

# Required: Session cookie signing secret
# Must be at least 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 
# ⚠️ DO NOT USE THE DEFAULT VALUE - Generate your own!
SESSION_SECRET=YOUR_BASE64_SECRET_HERE

# ===========================================
# AI / OPENAI (Optional but Recommended)
# ===========================================
# Optional: OpenAI API key for AI chat features
# Get from: https://platform.openai.com/api-keys
# Required if using AI features
OPENAI_API_KEY=sk-your-production-openai-key

# ===========================================
# FILE STORAGE (AWS S3)
# ===========================================
# Required if using S3 storage (recommended for production)
# Set to 'local' for local file storage (development only)
STORAGE_MODE=s3

# Required (if STORAGE_MODE=s3): AWS IAM user access key
# Get from: AWS Console → IAM → Users → askeuno-s3-user → Security credentials
# Format: Starts with AKIA...
AWS_ACCESS_KEY_ID=your-aws-access-key-id

# Required (if STORAGE_MODE=s3): AWS IAM user secret key
# Get from: AWS Console → IAM → Users → askeuno-s3-user → Security credentials
# ⚠️ Only shown once - save securely!
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Required (if STORAGE_MODE=s3): AWS region where bucket is located
# Common: us-east-1, us-east-2, us-west-1, us-west-2, eu-west-1
AWS_REGION=us-east-1

# Required (if STORAGE_MODE=s3): S3 bucket name
# Must match the bucket created in AWS Console
AWS_S3_BUCKET=askeuno-uploads

# ===========================================
# LIGHTSPEED R-SERIES
# ===========================================
LS_CLIENT_ID=your_lightspeed_client_id
LS_CLIENT_SECRET=your_lightspeed_client_secret
LS_REDIRECT_URI=https://askeuno.com/api/oauth/callback/lightspeed

# ===========================================
# APPLICATION URLs
# ===========================================
APP_URL=https://askeuno.com
FRONTEND_URL=https://askeuno.com

# ===========================================
# ERROR MONITORING (Sentry) - Optional but Recommended
# ===========================================
# Optional: Sentry DSN for backend error monitoring
# Get from: https://sentry.io → Create Project → Node.js → Copy DSN
# Format: https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Optional: Sentry DSN for frontend error monitoring
# Get from: https://sentry.io → Create Project → React → Copy DSN
# Can be same as SENTRY_DSN if using one project for both
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===========================================
# STRIPE (If using payments)
# ===========================================
# STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
# VITE_STRIPE_PUBLIC_KEY=pk_live_your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_xxx
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_xxx
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
# STRIPE_PRICE_ENTERPRISE_ANNUAL=price_xxx

# ===========================================
# GOOGLE OAUTH (For Google Sheets)
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://askeuno.com/api/oauth/callback/google-sheets

# ===========================================
# EMAIL (SendGrid - Optional)
# ===========================================
# SENDGRID_API_KEY=SG.your_sendgrid_api_key
# SENDGRID_FROM_EMAIL=noreply@askeuno.com
